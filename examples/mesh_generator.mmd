graph TD
    subgraph Entry ["event: triggers"]
        CLI_TRIGGER[CLI Invoke] --> SEED
        PARAM_CHANGE[Parameter Change] --> REACTIVE_GATE
        BATCH[Batch Request] --> SEED
    end

    subgraph Init
        SEED[Seed RNG] --> CONFIG[Mesh Config]
        CONFIG --> SNAPSHOT_INIT[Checkpoint: Init]
    end

    subgraph Primitive
        SNAPSHOT_INIT --> BASE{Base Shape}
        BASE -->|box| BOX[Box Mesh]
        BASE -->|sphere| SPHERE[UV Sphere]
        BASE -->|cylinder| CYLINDER[Cylinder]
        BASE -->|plane| PLANE[Subdivided Plane]
        BASE -->|custom| IMPORT[Import Base Mesh]
    end

    subgraph Sculpt ["sequence: deformation stack"]
        BOX --> DEFORM_ACCUM[Accumulate Deformations]
        SPHERE --> DEFORM_ACCUM
        CYLINDER --> DEFORM_ACCUM
        PLANE --> DEFORM_ACCUM
        IMPORT --> DEFORM_ACCUM
        DEFORM_ACCUM --> NOISE_D[Noise Displacement]
        NOISE_D --> TWIST[Twist / Bend]
        TWIST --> TAPER[Taper / Scale Gradient]
        TAPER --> LATTICE[Lattice Deform]
        LATTICE --> BOOL{Boolean Ops?}
        BOOL -->|yes| BOOLEAN[Boolean Combine]
        BOOL -->|no| SUBDIV[Subdivide]
        BOOLEAN --> SUBDIV
        SUBDIV --> REACTIVE_GATE[Reactive Update Point]
    end

    subgraph Approve_Sculpt
        REACTIVE_GATE --> SNAPSHOT_SCULPT[Checkpoint: Sculpt]
        SNAPSHOT_SCULPT --> PREVIEW_SCULPT[Render Wireframe Preview]
        PREVIEW_SCULPT --> HUMAN_SCULPT{Approve Sculpt?}
        HUMAN_SCULPT -->|approved| DETAIL_GATE[Begin Detail]
        HUMAN_SCULPT -->|rejected| SCULPT_TWEAK[Apply Feedback]
        SCULPT_TWEAK --> DEFORM_ACCUM
    end

    subgraph Detail ["parallel: surface detail"]
        DETAIL_GATE --> BEVEL[Edge Bevels]
        DETAIL_GATE --> CREASE[Crease Edges]
        DETAIL_GATE --> DAMAGE[Surface Damage]
        DETAIL_GATE --> PANEL_LINES[Panel Lines]
    end

    subgraph RaceDecimate ["race: decimation strategies"]
        BEVEL --> MERGE_MESH[Merge Detail]
        CREASE --> MERGE_MESH
        DAMAGE --> MERGE_MESH
        PANEL_LINES --> MERGE_MESH
        MERGE_MESH --> VALIDATE{Valid Mesh?}
        VALIDATE -->|yes| QUADRIC[Quadric Error Decimate]
        VALIDATE -->|yes| VERTEX_CLUSTER[Vertex Clustering]
        VALIDATE -->|yes| EDGE_COLLAPSE[Edge Collapse]
        VALIDATE -->|no| REPAIR[Repair Mesh]
        REPAIR --> VALIDATE
        QUADRIC --> DEC_PICK{Best Quality/Count?}
        VERTEX_CLUSTER --> DEC_PICK
        EDGE_COLLAPSE --> DEC_PICK
    end

    subgraph LOD_Gen ["subgraph: lod_pipeline"]
        DEC_PICK --> LOD_ACCUM[Accumulate LODs]
        LOD_ACCUM --> LOD0[LOD 0 - Full Detail]
        LOD0 --> LOD1[LOD 1 - 50%]
        LOD1 --> LOD2[LOD 2 - 25%]
        LOD2 --> LOD3[LOD 3 - 10%]
        LOD3 --> LOD_CHAIN[Chain LODs]
    end

    subgraph UV ["sequence: UV pipeline"]
        LOD_CHAIN --> UNWRAP[UV Unwrap]
        UNWRAP --> UV_PACK[Pack UV Islands]
        UV_PACK --> UV_CHECK{UV Overlap?}
        UV_CHECK -->|no| LIGHTMAP[Lightmap UV]
        UV_CHECK -->|yes| UV_REPACK[Repack with Margin]
        UV_REPACK --> UV_CHECK
    end

    subgraph Materials
        LIGHTMAP --> SNAPSHOT_UV[Checkpoint: UV Complete]
        SNAPSHOT_UV --> ASSIGN_MAT[Assign Materials]
        ASSIGN_MAT --> VERTEX_COLOR[Bake Vertex Colors]
        VERTEX_COLOR --> HUMAN_FINAL{Approve Final?}
        HUMAN_FINAL -->|approved| EXPORT_GATE[Ready for Export]
        HUMAN_FINAL -->|rejected| MAT_TWEAK[Apply Feedback]
        MAT_TWEAK --> ASSIGN_MAT
    end

    subgraph Export ["parallel: outputs"]
        EXPORT_GATE --> GLTF[glTF Binary]
        EXPORT_GATE --> OBJ[OBJ + MTL]
        EXPORT_GATE --> FBX[FBX]
        EXPORT_GATE --> UNITY[Unity Prefab Data]
        EXPORT_GATE --> STATS[Mesh Stats]
        EXPORT_GATE --> HISTORY[Generation History]
    end

