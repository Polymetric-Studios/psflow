graph TD
    subgraph Intake ["intake"]
        RECEIVE[Receive Order] --> VALIDATE[Validate Order]
        VALIDATE --> FRAUD{Fraud Check}
        FRAUD -->|pass| ENRICH[Enrich Customer]
        FRAUD -->|fail| REJECT[Reject Order]
    end

    subgraph Payment
        ENRICH --> CALC_TAX[Calculate Tax]
        ENRICH --> CALC_SHIP[Calculate Shipping]
        CALC_TAX --> TOTAL[Compute Total]
        CALC_SHIP --> TOTAL
        TOTAL --> CHARGE[Charge Payment]
        CHARGE --> PAY_OK{Payment OK?}
        PAY_OK -->|yes| RESERVE[Reserve Inventory]
        PAY_OK -->|no| RETRY{Retries Left?}
        RETRY -->|yes| CHARGE
        RETRY -->|no| CANCEL[Cancel Order]
    end

    subgraph Fulfill
        RESERVE --> PICK[Pick Items]
        PICK --> PACK[Pack Shipment]
        PACK --> LABEL[Generate Label]
        LABEL --> SHIP[Ship Package]
    end

    subgraph Notify ["notifications"]
        SHIP --> CONFIRM[Send Confirmation]
        CONFIRM --> TRACK[Tracking Email]
        REJECT --> DECLINE[Send Decline Notice]
        CANCEL --> REFUND[Process Refund]
        REFUND --> DECLINE
    end

