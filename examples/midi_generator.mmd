graph TD
    subgraph Entry ["event: triggers"]
        CLI_TRIGGER[CLI Invoke] --> SEED
        MIDI_IN[MIDI File Input] --> SEED
        PARAM_CHANGE[Parameter Change] --> REACTIVE_GATE
    end

    subgraph Init
        SEED[Seed RNG] --> SONG[Song Config]
        SONG --> SCALE[Build Scale]
        SONG --> TEMPO[Tempo Map]
        SCALE --> SNAPSHOT_INIT[Checkpoint: Init]
        TEMPO --> SNAPSHOT_INIT
    end

    subgraph Structure
        SNAPSHOT_INIT --> CHORDS[Generate Chord Progression]
        CHORDS --> FORM[Arrange Form]
        FORM --> HUMAN_FORM{Approve Form?}
        HUMAN_FORM -->|approved| SNAPSHOT_STRUCT[Checkpoint: Structure]
        HUMAN_FORM -->|rejected| FORM_TWEAK[Apply Feedback]
        FORM_TWEAK --> CHORDS
    end

    subgraph RaceArrangement ["race: arrangements"]
        SNAPSHOT_STRUCT --> ARR_DENSE[Dense Arrangement]
        SNAPSHOT_STRUCT --> ARR_SPARSE[Sparse Arrangement]
        SNAPSHOT_STRUCT --> ARR_BUILDING[Building Arrangement]
        ARR_DENSE --> ARR_PICK{First Balanced?}
        ARR_SPARSE --> ARR_PICK
        ARR_BUILDING --> ARR_PICK
    end

    subgraph Tracks ["parallel: voices"]
        ARR_PICK --> MELODY[Melody Track]
        ARR_PICK --> BASS[Bass Track]
        ARR_PICK --> DRUMS[Drum Track]
        ARR_PICK --> PAD[Pad Track]
    end

    subgraph Melody_Detail ["subgraph: melody_voice"]
        MELODY --> M_MOTIF[Generate Motifs]
        M_MOTIF --> M_ACCUM[Accumulate Phrases]
        M_ACCUM --> M_DEVELOP[Develop Over Sections]
        M_DEVELOP --> M_VARY[Apply Variation]
        M_VARY --> M_ORNAMENT[Ornamentation]
        M_ORNAMENT --> M_EXPR[Add Expression]
    end

    subgraph Bass_Detail ["subgraph: bass_voice"]
        BASS --> B_ROOTS[Root Notes]
        B_ROOTS --> B_ACCUM[Accumulate Bass Line]
        B_ACCUM --> B_WALK[Walking Lines]
        B_WALK --> B_APPROACH[Approach Notes]
        B_APPROACH --> B_EXPR[Add Expression]
    end

    subgraph Drums_Detail ["subgraph: drum_voice"]
        DRUMS --> D_GROOVE[Base Groove]
        D_GROOVE --> D_VARIATION[Section Variations]
        D_VARIATION --> D_FILL[Place Fills]
        D_FILL --> D_GHOST[Ghost Notes]
        D_GHOST --> D_DYNAMICS[Dynamic Shaping]
    end

    subgraph Pad_Detail ["subgraph: pad_voice"]
        PAD --> P_VOICE[Voice Chords]
        P_VOICE --> P_RHYTHM[Rhythmic Pattern]
        P_RHYTHM --> P_SUSTAIN[Sustain Shaping]
    end

    subgraph Refine
        M_EXPR --> MERGE[Merge Tracks]
        B_EXPR --> MERGE
        D_DYNAMICS --> MERGE
        P_SUSTAIN --> MERGE
        MERGE --> SNAPSHOT_MERGED[Checkpoint: Merged]
        SNAPSHOT_MERGED --> QUANT[Quantize]
        QUANT --> HUMANIZE[Humanize]
        HUMANIZE --> REACTIVE_GATE[Reactive Update Point]
    end

    subgraph Validate
        REACTIVE_GATE --> VALIDATE{Harmonically Valid?}
        VALIDATE -->|yes| DENSITY{Density Balanced?}
        VALIDATE -->|no| FIX[Fix Clashes]
        FIX --> MERGE
        DENSITY -->|yes| HUMAN_MIX{Approve Mix?}
        DENSITY -->|no| THIN[Thin Overlaps]
        THIN --> QUANT
    end

    subgraph Approve
        HUMAN_MIX -->|approved| MASTER[Master]
        HUMAN_MIX -->|rejected| MIX_TWEAK[Apply Mix Feedback]
        MIX_TWEAK --> MERGE
    end

    subgraph Master
        MASTER --> VELOCITY_CURVE[Global Velocity Curve]
        VELOCITY_CURVE --> DYNAMICS[Dynamic Range]
        DYNAMICS --> FINAL_CHECK{Final Validation}
        FINAL_CHECK -->|pass| EXPORT_GATE[Ready for Export]
        FINAL_CHECK -->|fail| DYNAMICS
    end

    subgraph Export ["parallel: outputs"]
        EXPORT_GATE --> MIDI_FILE[MIDI File]
        EXPORT_GATE --> SCORE[Text Score]
        EXPORT_GATE --> LEAD_SHEET[Lead Sheet]
        EXPORT_GATE --> MMD[Mermaid Structure]
        EXPORT_GATE --> HISTORY[Generation History]
    end

