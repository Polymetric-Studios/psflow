graph TD
    subgraph Entry ["event: triggers"]
        CLI_TRIGGER[CLI Invoke] --> SEED
        WEBHOOK[Webhook Trigger] --> SEED
        WATCH[File Watch Trigger] --> SEED
    end

    subgraph Init
        SEED[Seed RNG] --> CONFIG[Load Config]
        CONFIG --> SNAPSHOT_INIT[Checkpoint: Init]
    end

    subgraph Generate ["parallel: rooms"]
        SNAPSHOT_INIT --> ROOMS[Generate Rooms]
        ROOMS --> R_ACCUM[Accumulate Room List]
        R_ACCUM --> R_DETAIL[Room Details]
        R_DETAIL --> R_THEME[Apply Theme]
    end

    subgraph RaceLayout ["race: layout strategies"]
        R_THEME --> MST_LAYOUT[MST + Loops]
        R_THEME --> GRID_LAYOUT[Grid Snap]
        R_THEME --> ORGANIC_LAYOUT[Organic Growth]
        MST_LAYOUT --> LAYOUT_PICK{First Valid?}
        GRID_LAYOUT --> LAYOUT_PICK
        ORGANIC_LAYOUT --> LAYOUT_PICK
    end

    subgraph Connect
        LAYOUT_PICK --> CORR[Place Corridors]
        CORR --> DOORS[Place Doors]
        DOORS --> SNAPSHOT_LAYOUT[Checkpoint: Layout]
    end

    subgraph Approve
        SNAPSHOT_LAYOUT --> PREVIEW_MAP[Render Preview Map]
        PREVIEW_MAP --> HUMAN_LAYOUT{Approve Layout?}
        HUMAN_LAYOUT -->|approved| POPULATE_GATE[Begin Population]
        HUMAN_LAYOUT -->|rejected| TWEAK[Apply Feedback]
        TWEAK --> ROOMS
    end

    subgraph Populate ["parallel: content"]
        POPULATE_GATE --> KEYS[Distribute Keys]
        POPULATE_GATE --> MONSTERS[Place Monsters]
        POPULATE_GATE --> LOOT[Place Loot]
        POPULATE_GATE --> TRAPS[Place Traps]
        POPULATE_GATE --> SECRETS[Hide Secrets]
    end

    subgraph MergeContent
        KEYS --> CONTENT_ACCUM[Accumulate Content]
        MONSTERS --> CONTENT_ACCUM
        LOOT --> CONTENT_ACCUM
        TRAPS --> CONTENT_ACCUM
        SECRETS --> CONTENT_ACCUM
        CONTENT_ACCUM --> MERGE[Merge Dungeon]
    end

    subgraph Validate
        MERGE --> SNAPSHOT_POPULATED[Checkpoint: Populated]
        SNAPSHOT_POPULATED --> SOLVE{Solvable?}
        SOLVE -->|yes| BALANCE{Balanced?}
        SOLVE -->|no| REGEN[Relax Constraints]
        REGEN --> ROOMS
        BALANCE -->|yes| EXPORT_GATE[Ready for Export]
        BALANCE -->|no| REBALANCE[Adjust Difficulty]
        REBALANCE --> MONSTERS
    end

    subgraph FlavorText ["subgraph: flavor_text"]
        EXPORT_GATE --> FT_ROOMS[Room Descriptions]
        FT_ROOMS --> FT_ITEMS[Item Descriptions]
        FT_ITEMS --> FT_LORE[Lore Fragments]
        FT_LORE --> FT_MERGE[Merge Flavor]
    end

    subgraph Export ["parallel: outputs"]
        FT_MERGE --> ASCII[ASCII Map]
        FT_MERGE --> MMD[Mermaid Graph]
        FT_MERGE --> JSON[JSON Data]
        FT_MERGE --> HISTORY[Generation History]
    end

