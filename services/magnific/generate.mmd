graph TD
    START[Start] --> SUBMIT[Start TTI]
    SUBMIT --> PARSE_START[Parse family + tokens]
    PARSE_START --> CHANNEL[Build channel]
    CHANNEL --> PUBLISH_TOKENS[Publish request_tokens]

    subgraph render ["loop: render_images"]
        RENDER[Render Image] --> ACC_IDS[Accumulate creation ids]
    end

    PUBLISH_TOKENS --> RENDER
    ACC_IDS --> WAIT[Wait For Completion]
    WAIT --> PARSE_URLS[Build result URLs]
    PARSE_URLS --> PUBLISH_URLS[Publish image_urls]

    subgraph downloads ["parallel-loop: download_images"]
        DOWNLOAD[Download Image]
    end

    PUBLISH_URLS --> DOWNLOAD
    DOWNLOAD --> DONE[Done]

