graph TD
    subgraph Init
        SEED[Seed RNG] --> CONFIG[Load Config]
    end

    subgraph Generate ["parallel: rooms"]
        CONFIG --> ROOMS[Generate Rooms]
        ROOMS --> R_DETAIL[Room Details]
        R_DETAIL --> R_THEME[Apply Theme]
    end

    subgraph Connect
        R_THEME --> CORR[Place Corridors]
        CORR --> DOORS[Place Doors]
    end

    subgraph Populate ["parallel: content"]
        DOORS --> KEYS[Distribute Keys]
        DOORS --> MONSTERS[Place Monsters]
        DOORS --> LOOT[Place Loot]
    end

    KEYS --> MERGE[Merge Dungeon]
    MONSTERS --> MERGE
    LOOT --> MERGE

    subgraph Validate
        MERGE --> SOLVE{Solvable?}
        SOLVE -->|yes| BALANCE{Balanced?}
        SOLVE -->|no| REGEN[Relax Constraints]
        REGEN --> ROOMS
        BALANCE -->|yes| EXPORT[Export]
        BALANCE -->|no| REBALANCE[Adjust Difficulty]
        REBALANCE --> MONSTERS
    end

    subgraph Export ["parallel: outputs"]
        EXPORT --> ASCII[ASCII Map]
        EXPORT --> MMD[Mermaid Graph]
        EXPORT --> JSON[JSON Data]
    end

