graph TD
    subgraph Entry ["event: triggers"]
        CLI_TRIGGER[CLI Invoke] --> SEED
        WATCH[File Watch Trigger] --> REACTIVE_GATE
        PARAM_CHANGE[Parameter Change] --> REACTIVE_GATE
    end

    subgraph Init
        SEED[Seed RNG] --> CONFIG[Material Config]
        CONFIG --> SNAPSHOT_INIT[Checkpoint: Init]
    end

    subgraph RaceNoise ["race: noise strategies"]
        SNAPSHOT_INIT --> SIMPLEX[Simplex FBM]
        SNAPSHOT_INIT --> WORLEY[Worley Cellular]
        SNAPSHOT_INIT --> VORONOI[Voronoi Cracks]
        SIMPLEX --> NOISE_PICK{First Interesting?}
        WORLEY --> NOISE_PICK
        VORONOI --> NOISE_PICK
    end

    subgraph Base ["parallel: base layers"]
        NOISE_PICK --> NOISE[Selected Noise]
        SNAPSHOT_INIT --> GRADIENT[Gradient Map]
        SNAPSHOT_INIT --> PATTERN[Tile Pattern]
    end

    subgraph LayerStack ["sequence: layer accumulation"]
        NOISE --> LAYER_ACCUM[Accumulate Layers]
        GRADIENT --> LAYER_ACCUM
        PATTERN --> LAYER_ACCUM
        LAYER_ACCUM --> BLEND[Blend Layers]
        BLEND --> WARP[Domain Warp]
        WARP --> REACTIVE_GATE[Reactive Update Point]
        REACTIVE_GATE --> SNAPSHOT_BASE[Checkpoint: Base]
    end

    subgraph Approve
        SNAPSHOT_BASE --> PREVIEW_BASE[Render Base Preview]
        PREVIEW_BASE --> HUMAN_BASE{Approve Base?}
        HUMAN_BASE -->|approved| DERIVE_GATE[Begin PBR Derivation]
        HUMAN_BASE -->|rejected| TWEAK[Apply Feedback]
        TWEAK --> BLEND
    end

    subgraph DerivePBR ["subgraph: pbr_derive"]
        subgraph PBR_Maps ["parallel: PBR maps"]
            DERIVE_GATE --> ALBEDO[Albedo / Color]
            DERIVE_GATE --> NORMAL[Normal Map]
            DERIVE_GATE --> ROUGH[Roughness Map]
            DERIVE_GATE --> METAL[Metallic Map]
            DERIVE_GATE --> HEIGHT[Height Map]
            DERIVE_GATE --> AO[Ambient Occlusion]
            DERIVE_GATE --> EMISSIVE[Emissive Map]
        end

        subgraph PBR_Refine ["sequence: PBR refinement"]
            ALBEDO --> PBR_ACCUM[Accumulate Maps]
            NORMAL --> PBR_ACCUM
            ROUGH --> PBR_ACCUM
            METAL --> PBR_ACCUM
            HEIGHT --> PBR_ACCUM
            AO --> PBR_ACCUM
            EMISSIVE --> PBR_ACCUM
            PBR_ACCUM --> CROSS_CORRECT[Cross-Map Correction]
        end
    end

    subgraph Validate
        CROSS_CORRECT --> SNAPSHOT_DERIVED[Checkpoint: Derived]
        SNAPSHOT_DERIVED --> TILE_CHECK{Seamless?}
        TILE_CHECK -->|yes| ENERGY_CHECK{Energy Conserving?}
        TILE_CHECK -->|no| FIX_SEAM[Fix Seams]
        FIX_SEAM --> TILE_CHECK
        ENERGY_CHECK -->|yes| PACK[Pack Channels]
        ENERGY_CHECK -->|no| FIX_ENERGY[Correct PBR Values]
        FIX_ENERGY --> CROSS_CORRECT
    end

    subgraph RacePack ["race: compression"]
        PACK --> BC7[BC7 Compress]
        PACK --> ASTC[ASTC Compress]
        PACK --> ETC2[ETC2 Compress]
        BC7 --> PACK_PICK{Best Quality/Size?}
        ASTC --> PACK_PICK
        ETC2 --> PACK_PICK
    end

    subgraph Export ["parallel: outputs"]
        PACK_PICK --> PNG[PNG Maps]
        PACK_PICK --> KTX[KTX2 Compressed]
        PACK_PICK --> PREVIEW[Preview Render]
        PACK_PICK --> MANIFEST[Material Manifest]
        PACK_PICK --> HISTORY[Generation History]
    end

